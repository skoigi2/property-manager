// Property Manager — Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Organisation (multi-tenancy) ────────────────────────────────────────────

model Organization {
  id              String                       @id @default(cuid())
  name            String
  logoUrl         String?
  address         String?
  phone           String?
  email           String?
  website         String?
  isActive              Boolean                      @default(true)
  locale                String                       @default("en-US")
  defaultCurrency       String                       @default("USD")
  vatRegistrationNumber String?
  bankName              String?
  bankAccountName       String?
  bankAccountNumber     String?
  bankBranch            String?
  mpesaPaybill          String?
  mpesaAccountNumber    String?
  mpesaTill             String?
  paymentInstructions   String?
  // ── SaaS billing ──────────────────────────────────────────────────────────
  pricingTier           PricingTier                  @default(TRIAL)
  trialEndsAt           DateTime?
  subscriptionStatus    String?                      // "trialing"|"active"|"past_due"|"canceled"
  currentPeriodEnd      DateTime?
  paddleCustomerId      String?
  paddleSubscriptionId  String?
  paddleEventId         String?                      // last processed webhook event (idempotency)
  users                 User[]
  properties            Property[]
  memberships           UserOrganizationMembership[]
  vendors                Vendor[]
  taxConfigurations      TaxConfiguration[]
  complianceCertificates ComplianceCertificate[]
  notificationLogs       NotificationLog[]
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
}

model UserOrganizationMembership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

// ─── Auth (NextAuth / Auth.js) ────────────────────────────────────────────────

enum UserRole {
  ADMIN
  OWNER
  MANAGER
  ACCOUNTANT
}

model User {
  id               String           @id @default(cuid())
  name             String?
  email            String?          @unique
  emailVerified    DateTime?
  image            String?
  password             String?
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?
  role             UserRole         @default(MANAGER)
  phone            String?
  isActive         Boolean          @default(true)
  organizationId          String?
  organization            Organization?                @relation(fields: [organizationId], references: [id])
  organizationMemberships UserOrganizationMembership[]
  propertyAccess          PropertyAccess[]
  ownedProperties   Property[]       @relation("PropertyOwner")
  managedProperties Property[]       @relation("PropertyManager")
  ownerInvoices     OwnerInvoice[]   @relation("OwnerInvoices")
  accounts         Account[]
  sessions         Session[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([organizationId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application Models ───────────────────────────────────────────────────────

enum PropertyType {
  AIRBNB
  LONGTERM
}

enum PropertyCategory {
  RESIDENTIAL
  OFFICE
  INDUSTRIAL
  RETAIL
  MIXED_USE
  OTHER
}

enum InsuranceType {
  BUILDING
  PUBLIC_LIABILITY
  CONTENTS
  OTHER
}

enum PremiumFrequency {
  MONTHLY
  QUARTERLY
  BIANNUALLY
  ANNUALLY
}

enum MaintenanceFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  BIANNUALLY
  ANNUALLY
}

enum AssetCategory {
  GENERATOR
  LIFT
  HVAC
  ELECTRICAL
  PLUMBING
  SECURITY
  APPLIANCE
  FURNITURE
  IT_EQUIPMENT
  VEHICLE
  OTHER
}

enum UnitType {
  BEDSITTER
  ONE_BED
  TWO_BED
  THREE_BED
  FOUR_BED
  PENTHOUSE
  COMMERCIAL
  OTHER
}

enum UnitStatus {
  ACTIVE
  VACANT
  LISTED
  UNDER_NOTICE
  MAINTENANCE
  OWNER_OCCUPIED
}

enum IncomeType {
  LONGTERM_RENT
  SERVICE_CHARGE
  DEPOSIT
  AIRBNB
  UTILITY_RECOVERY
  OTHER
  LETTING_FEE
  RENEWAL_FEE
  VACANCY_FEE
  SETUP_FEE_INSTALMENT
  CONSULTANCY_FEE
}

enum Platform {
  AIRBNB
  BOOKING_COM
  DIRECT
  AGENT
}

enum ExpenseScope {
  UNIT
  PROPERTY
  PORTFOLIO
}

enum ExpenseCategory {
  SERVICE_CHARGE
  MANAGEMENT_FEE
  WIFI
  WATER
  ELECTRICITY
  CLEANER
  CONSUMABLES
  MAINTENANCE
  REINSTATEMENT
  CAPITAL
  OTHER
}

enum PettyCashType {
  IN
  OUT
}

enum PettyCashStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DocumentCategory {
  LEASE_AGREEMENT
  ID_COPY
  TAX_ID
  PAYMENT_RECEIPT
  RENEWAL_NOTICE
  CORRESPONDENCE
  OTHER
}

enum ExpenseDocumentCategory {
  INVOICE
  RECEIPT
  QUOTE
  CONTRACT
  PHOTO
  OTHER
}

enum RenewalStage {
  NONE
  NOTICE_SENT
  TERMS_AGREED
  RENEWED
}

enum MaintenanceCategory {
  PLUMBING
  ELECTRICAL
  STRUCTURAL
  APPLIANCE
  PAINTING
  CLEANING
  SECURITY
  PEST_CONTROL
  OTHER
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  AWAITING_PARTS
  DONE
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum OwnerInvoiceType {
  LETTING_FEE
  PERIODIC_LETTING_FEE
  RENEWAL_FEE
  MANAGEMENT_FEE
  VACANCY_FEE
  SETUP_FEE_INSTALMENT
  CONSULTANCY_FEE
}

enum ArrearsStage {
  INFORMAL_REMINDER
  DEMAND_LETTER
  LEGAL_NOTICE
  EVICTION
  RESOLVED
}

enum RecurringFrequency {
  MONTHLY
  QUARTERLY
  ANNUAL
  BIANNUAL
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum VendorCategory {
  CONTRACTOR
  SUPPLIER
  UTILITY_PROVIDER
  SERVICE_PROVIDER
  CONSULTANT
  OTHER
}

enum LineItemCategory {
  LABOUR
  MATERIAL
  QUOTE
}

enum LineItemPaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

// ─── Property Access Control ──────────────────────────────────────────────────

model PropertyAccess {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  grantedAt  DateTime @default(now())

  @@unique([userId, propertyId])
}

// ─── Core Models ─────────────────────────────────────────────────────────────

model Property {
  id                   String            @id @default(cuid())
  name                 String
  type                 PropertyType
  category             PropertyCategory?
  categoryOther        String?
  address              String?
  city                 String?
  description          String?
  logoUrl              String?
  organizationId       String?
  organization         Organization?     @relation(fields: [organizationId], references: [id])
  ownerId              String?
  owner                User?             @relation("PropertyOwner", fields: [ownerId], references: [id])
  managerId            String?
  manager              User?             @relation("PropertyManager", fields: [managerId], references: [id])
  managementFeeRate    Float?
  managementFeeFlat    Float?
  serviceChargeDefault Float?
  currency              String            @default("USD")
  vatRegistrationNumber String?
  units                 Unit[]
  expenses              ExpenseEntry[]
  propertyAccess        PropertyAccess[]
  pettyCash             PettyCash[]
  maintenanceJobs       MaintenanceJob[]
  arrearsCases          ArrearsCase[]
  recurringExpenses     RecurringExpense[]
  insurancePolicies     InsurancePolicy[]
  assets                Asset[]
  agreement             ManagementAgreement?
  conditionReports      BuildingConditionReport[]
  ownerInvoices         OwnerInvoice[]
  maintenanceSchedules   AssetMaintenanceSchedule[] @relation("PropertyMaintenanceSchedules")
  taxConfigurations      TaxConfiguration[]
  complianceCertificates ComplianceCertificate[]
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
}

model Unit {
  id            String                @id @default(cuid())
  unitNumber    String
  propertyId    String
  type          UnitType
  floor         Int?
  sizeSqm       Float?
  monthlyRent   Float?
  status        UnitStatus            @default(ACTIVE)
  vacantSince   DateTime?
  description   String?
  amenities     String[]
  property      Property              @relation(fields: [propertyId], references: [id])
  tenants           Tenant[]
  incomeEntries     IncomeEntry[]
  expenses          ExpenseEntry[]
  feeConfigs        ManagementFeeConfig[]
  maintenanceJobs   MaintenanceJob[]
  recurringExpenses  RecurringExpense[]
  expenseAllocations ExpenseUnitAllocation[]
  assets             Asset[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@unique([propertyId, unitNumber])
}

model Tenant {
  id               String        @id @default(cuid())
  name             String
  email            String?
  phone            String?
  nationalId       String?
  taxIdNumber      String?           @map("kraPinNumber")
  unitId           String
  depositAmount    Float
  depositPaidDate  DateTime?
  leaseStart       DateTime
  leaseEnd         DateTime?
  monthlyRent      Float
  serviceCharge    Float         @default(0)
  rentDueDay       Int           @default(1)
  isActive         Boolean          @default(true)
  vacatedDate      DateTime?
  notes            String?
  renewalStage     RenewalStage     @default(NONE)
  proposedRent     Float?
  proposedLeaseEnd DateTime?
  renewalNotes     String?
  escalationRate   Float?
  chargeLatePenalty Boolean         @default(false)
  isTaxExempt      Boolean         @default(false)
  portalToken          String?          @unique
  portalTokenExpiresAt DateTime?
  unit             Unit             @relation(fields: [unitId], references: [id])
  incomeEntries     IncomeEntry[]
  invoices          Invoice[]
  documents         TenantDocument[]
  arrearsCases      ArrearsCase[]
  depositSettlement DepositSettlement?
  rentHistory          RentHistory[]
  communicationLogs    CommunicationLog[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([unitId])
  @@index([isActive])
  @@index([unitId, isActive])
  @@index([leaseEnd])
  @@index([portalToken])
}

model RentHistory {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  monthlyRent   Float
  effectiveDate DateTime
  reason        String?
  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, effectiveDate])
}

model IncomeEntry {
  id                String     @id @default(cuid())
  date              DateTime
  checkIn           DateTime?
  checkOut          DateTime?
  unitId            String
  tenantId          String?
  invoiceId         String?
  ownerInvoiceId    String?
  type              IncomeType
  grossAmount       Float
  agentCommission   Float      @default(0)
  commissionPaidAt  DateTime?
  platform          Platform?
  agentName         String?
  nightlyRate       Float?
  note              String?
  taxConfigId       String?
  taxRate           Float?
  taxAmount         Float?
  taxType           TaxType?
  unit              Unit         @relation(fields: [unitId], references: [id])
  tenant            Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  invoice           Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  ownerInvoice      OwnerInvoice? @relation(fields: [ownerInvoiceId], references: [id], onDelete: SetNull)
  bookingGuests     BookingGuest[]
  createdAt         DateTime   @default(now())

  @@index([date])
  @@index([unitId, date])
  @@index([tenantId])
  @@index([invoiceId])
  @@index([ownerInvoiceId])
  @@index([type])
  @@index([unitId, type])
}

model ExpenseEntry {
  id                String          @id @default(cuid())
  date              DateTime
  unitId            String?
  propertyId        String?
  scope             ExpenseScope
  category          ExpenseCategory
  amount            Float
  description       String?
  isSunkCost        Boolean         @default(false)
  paidFromPettyCash Boolean         @default(false)
  vendorId          String?
  unit              Unit?                    @relation(fields: [unitId], references: [id])
  property          Property?                @relation(fields: [propertyId], references: [id])
  vendor            Vendor?                  @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  lineItems         ExpenseLineItem[]
  unitAllocations   ExpenseUnitAllocation[]
  documents         ExpenseDocument[]
  maintenanceLogs   AssetMaintenanceLog[]
  createdAt         DateTime                 @default(now())

  @@index([date])
  @@index([propertyId, date])
  @@index([unitId])
  @@index([isSunkCost, date])
}

model ExpenseLineItem {
  id               String               @id @default(cuid())
  expenseId        String
  category         LineItemCategory
  description      String?
  amount           Float
  isVatable        Boolean              @default(false)
  taxConfigId      String?
  taxRate          Float?
  taxAmount        Float?
  taxType          TaxType?
  paymentStatus    LineItemPaymentStatus @default(UNPAID)
  amountPaid       Float                @default(0)
  paymentReference String?
  expense          ExpenseEntry         @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

model ExpenseUnitAllocation {
  id          String       @id @default(cuid())
  expenseId   String
  unitId      String
  shareAmount Float
  expense     ExpenseEntry @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  unit        Unit         @relation(fields: [unitId], references: [id])

  @@unique([expenseId, unitId])
}

model PettyCash {
  id              String          @id @default(cuid())
  date            DateTime
  type            PettyCashType
  amount          Float
  description     String
  receiptRef      String?
  propertyId      String?
  property        Property?       @relation(fields: [propertyId], references: [id])
  status          PettyCashStatus @default(APPROVED)
  approvedBy      String?
  approvedAt      DateTime?
  approvalNotes   String?
  rejectedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime        @default(now())

  @@index([propertyId])
  @@index([status])
}

model ManagementFeeConfig {
  id            String    @id @default(cuid())
  unitId        String
  ratePercent   Float     @default(0)
  flatAmount    Float?
  effectiveFrom DateTime
  effectiveTo   DateTime?
  unit          Unit      @relation(fields: [unitId], references: [id])
}

model MaintenanceJob {
  id               String              @id @default(cuid())
  propertyId       String
  unitId           String?
  title            String
  description      String?
  category         MaintenanceCategory @default(OTHER)
  priority         MaintenancePriority @default(MEDIUM)
  status           MaintenanceStatus   @default(OPEN)
  reportedBy       String?
  assignedTo       String?
  reportedDate     DateTime            @default(now())
  scheduledDate    DateTime?
  completedDate    DateTime?
  cost             Float?
  notes            String?
  expenseId        String?             // ID of the linked ExpenseEntry (once logged)
  vendorId         String?
  isEmergency        Boolean             @default(false)
  submittedViaPortal Boolean             @default(false)
  acknowledgedAt     DateTime?
  requiresApproval   Boolean             @default(false)
  approvedAt       DateTime?
  approvalNotes    String?
  property         Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit             Unit?               @relation(fields: [unitId], references: [id], onDelete: SetNull)
  vendor           Vendor?             @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([propertyId, status])
  @@index([status])
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  tenantId      String
  periodYear    Int
  periodMonth   Int
  rentAmount    Float
  serviceCharge Float         @default(0)
  otherCharges  Float         @default(0)
  totalAmount   Float
  dueDate       DateTime
  status        InvoiceStatus @default(DRAFT)
  paidAt        DateTime?
  paidAmount    Float?
  notes         String?
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  incomeEntries IncomeEntry[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([tenantId, periodYear, periodMonth])
  @@index([tenantId])
  @@index([status])
}

model OwnerInvoice {
  id            String           @id @default(cuid())
  invoiceNumber String           @unique
  propertyId    String
  ownerId       String?
  type          OwnerInvoiceType
  periodYear    Int
  periodMonth   Int
  lineItems     Json
  totalAmount   Float
  dueDate       DateTime
  status        InvoiceStatus    @default(DRAFT)
  paidAt        DateTime?
  paidAmount    Float?
  notes         String?
  property      Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  owner         User?            @relation("OwnerInvoices", fields: [ownerId], references: [id], onDelete: SetNull)
  incomeEntries IncomeEntry[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([propertyId])
  @@index([status])
  @@index([periodYear, periodMonth])
}

model ArrearsCase {
  id          String              @id @default(cuid())
  tenantId    String
  propertyId  String
  stage       ArrearsStage        @default(INFORMAL_REMINDER)
  amountOwed  Float
  notes       String?
  resolvedAt  DateTime?
  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property    Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  escalations ArrearsEscalation[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([tenantId])
  @@index([stage])
}

model ArrearsEscalation {
  id        String       @id @default(cuid())
  caseId    String
  stage     ArrearsStage
  notes     String?
  createdAt DateTime     @default(now())
  case      ArrearsCase  @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model RecurringExpense {
  id          String             @id @default(cuid())
  description String
  category    ExpenseCategory
  amount      Float
  scope       ExpenseScope
  propertyId  String?
  unitId      String?
  frequency   RecurringFrequency @default(MONTHLY)
  nextDueDate DateTime
  isActive    Boolean            @default(true)
  vendorId    String?
  property    Property?          @relation(fields: [propertyId], references: [id])
  unit        Unit?              @relation(fields: [unitId], references: [id])
  vendor      Vendor?            @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  schedule    AssetMaintenanceSchedule? @relation("ScheduleRecurringExpense")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([nextDueDate])
}

model AuditLog {
  id             String      @id @default(cuid())
  userId         String
  userEmail      String?
  action         AuditAction
  resource       String
  resourceId     String
  organizationId String?
  before         Json?
  after          Json?
  createdAt      DateTime    @default(now())

  @@index([resource, resourceId])
  @@index([userId])
  @@index([createdAt])
  @@index([organizationId])
}

model TenantDocument {
  id          String           @id @default(cuid())
  tenantId    String
  category    DocumentCategory @default(OTHER)
  label       String
  fileName    String
  storagePath String
  fileSize    Int?
  mimeType    String?
  uploadedAt  DateTime         @default(now())
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model ExpenseDocument {
  id          String                  @id @default(cuid())
  expenseId   String
  category    ExpenseDocumentCategory @default(OTHER)
  label       String
  fileName    String
  storagePath String
  fileSize    Int?
  mimeType    String?
  uploadedAt  DateTime                @default(now())
  expense     ExpenseEntry            @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([expenseId])
}

model DepositSettlement {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  depositHeld     Float
  deductions      Json     @default("[]")
  totalDeductions Float    @default(0)
  netRefunded     Float
  settledDate     DateTime
  notes           String?
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@index([tenantId])
}

// ─── Insurance ───────────────────────────────────────────────────────────────

model InsurancePolicy {
  id               String            @id @default(cuid())
  propertyId       String
  property         Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  type             InsuranceType
  typeOther        String?
  insurer          String
  policyNumber     String
  startDate        DateTime
  endDate          DateTime
  premiumAmount    Float?
  premiumFrequency PremiumFrequency?
  coverageAmount   Float?
  brokerName       String?
  brokerContact    String?
  notes            String?
  documents        InsurancePolicyDocument[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([propertyId])
  @@index([endDate])
}

model InsurancePolicyDocument {
  id         String          @id @default(cuid())
  policyId   String
  policy     InsurancePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  label      String
  fileName   String
  fileUrl    String
  fileSize   Int?
  mimeType   String?
  uploadedAt DateTime        @default(now())

  @@index([policyId])
}

// ─── Asset Register ───────────────────────────────────────────────────────────

model Asset {
  id              String        @id @default(cuid())
  propertyId      String
  property        Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unitId          String?
  unit            Unit?         @relation(fields: [unitId], references: [id])
  name            String
  category        AssetCategory
  categoryOther   String?
  serialNumber    String?
  modelNumber     String?
  purchaseDate    DateTime?
  purchaseCost    Float?
  warrantyExpiry  DateTime?
  serviceProvider String?
  serviceContact  String?
  vendorId        String?
  notes           String?
  vendor               Vendor?         @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  documents            AssetDocument[]
  maintenanceSchedules AssetMaintenanceSchedule[]
  maintenanceLogs      AssetMaintenanceLog[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([propertyId])
  @@index([warrantyExpiry])
}

model AssetDocument {
  id         String   @id @default(cuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  label      String
  fileName   String
  fileUrl    String
  fileSize   Int?
  mimeType   String?
  uploadedAt DateTime @default(now())

  @@index([assetId])
}

model AssetMaintenanceSchedule {
  id                 String               @id @default(cuid())
  assetId            String?
  asset              Asset?               @relation(fields: [assetId], references: [id], onDelete: Cascade)
  propertyId         String?
  property           Property?            @relation("PropertyMaintenanceSchedules", fields: [propertyId], references: [id], onDelete: Cascade)
  taskName           String
  description        String?
  frequency          MaintenanceFrequency
  lastDone           DateTime?
  nextDue            DateTime?
  isActive           Boolean              @default(true)
  taskCategory       String?
  estimatedCost      Float?
  recurringExpenseId String?              @unique
  recurringExpense   RecurringExpense?    @relation("ScheduleRecurringExpense", fields: [recurringExpenseId], references: [id], onDelete: SetNull)
  logs               AssetMaintenanceLog[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([assetId])
  @@index([propertyId])
  @@index([recurringExpenseId])
  @@index([nextDue])
}

model AssetMaintenanceLog {
  id          String                    @id @default(cuid())
  assetId     String
  asset       Asset                     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  scheduleId  String?
  schedule    AssetMaintenanceSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  expenseId   String?
  expense     ExpenseEntry?             @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  date        DateTime
  description String
  cost        Float?
  technician  String?
  vendorId    String?
  notes       String?
  vendor      Vendor?                   @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  createdAt   DateTime                  @default(now())

  @@index([assetId])
  @@index([scheduleId])
  @@index([expenseId])
  @@index([vendorId])
}

// ─── Management Agreement ─────────────────────────────────────────────────────

model ManagementAgreement {
  id                             String   @id @default(cuid())
  propertyId                     String   @unique
  property                       Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  // Fee rates
  managementFeeRate              Float    @default(8.5)
  vacancyFeeRate                 Float    @default(5.0)
  vacancyFeeThresholdMonths      Int      @default(9)
  newLettingFeeRate              Float    @default(50.0)
  leaseRenewalFeeFlat            Float    @default(3000)
  shortTermLettingFeeRate        Float    @default(10.0)
  repairAuthorityLimit           Float    @default(100000)
  setupFeeTotal                  Float?
  setupFeeInstalments            Int      @default(3)

  // Deadlines
  rentRemittanceDay              Int      @default(5)
  mgmtFeeInvoiceDay              Int      @default(7)
  landlordPaymentDays            Int      @default(2)

  // KPI targets
  kpiStartDate                   DateTime?
  kpiOccupancyTarget             Float    @default(90)
  kpiRentCollectionTarget        Float    @default(90)
  kpiExpenseRatioTarget          Float    @default(85)
  kpiTenantTurnoverTarget        Float    @default(90)
  kpiDaysToLeaseTarget           Int      @default(60)
  kpiRenewalRateTarget           Float    @default(90)
  kpiMaintenanceCompletionTarget Float    @default(95)
  kpiEmergencyResponseHrs        Int      @default(24)
  kpiStandardResponseHrs         Int      @default(96)
  latePaymentInterestRate        Float    @default(0)   // annual %, e.g. 5.0

  // Tenant invoice payment details (where tenants send rent)
  tenantKraPin                   String?
  tenantBankName                 String?
  tenantBankAccountName          String?
  tenantBankAccountNumber        String?
  tenantBankBranch               String?
  tenantMpesaPaybill             String?
  tenantMpesaAccountNumber       String?
  tenantMpesaTill                String?
  tenantPaymentInstructions      String?

  // Manager billing details (where owner sends management fees)
  mgmtKraPin                     String?
  mgmtBankName                   String?
  mgmtBankAccountName            String?
  mgmtBankAccountNumber          String?
  mgmtBankBranch                 String?
  mgmtMpesaPaybill               String?
  mgmtMpesaAccountNumber         String?
  mgmtMpesaTill                  String?
  mgmtPaymentInstructions        String?

  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt

  @@index([propertyId])
}

// ─── Building Condition Reports ───────────────────────────────────────────────

model BuildingConditionReport {
  id               String   @id @default(cuid())
  propertyId       String
  property         Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reportDate       DateTime
  inspector        String?
  overallCondition String
  summary          String?
  items            Json?
  nextReviewDate   DateTime?
  createdAt        DateTime @default(now())

  @@index([propertyId])
  @@index([reportDate])
}

// ─── Airbnb Guest Management ──────────────────────────────────────────────────

model AirbnbGuest {
  id             String          @id @default(cuid())
  name           String
  email          String?
  phone          String?
  nationality    String?
  passportNumber String?
  preferences    String?
  bookings       BookingGuest[]
  documents      GuestDocument[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([name])
  @@index([email])
}

model BookingGuest {
  id            String      @id @default(cuid())
  guestId       String
  incomeEntryId String
  isPrimary     Boolean     @default(false)
  guest         AirbnbGuest @relation(fields: [guestId], references: [id], onDelete: Cascade)
  incomeEntry   IncomeEntry @relation(fields: [incomeEntryId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([guestId, incomeEntryId])
  @@index([incomeEntryId])
  @@index([guestId])
}

model GuestDocument {
  id          String      @id @default(cuid())
  guestId     String
  label       String
  fileName    String
  storagePath String
  fileSize    Int?
  mimeType    String?
  uploadedAt  DateTime    @default(now())
  guest       AirbnbGuest @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@index([guestId])
}

model Agent {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  agency    String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

// ─── Vendor Registry ──────────────────────────────────────────────────────────

model Vendor {
  id             String         @id @default(cuid())
  organizationId String?
  organization   Organization?  @relation(fields: [organizationId], references: [id])
  name           String
  category       VendorCategory @default(OTHER)
  phone          String?
  email          String?
  taxId          String?           @map("kraPin")
  bankDetails    String?
  notes          String?
  isActive       Boolean        @default(true)
  expenses        ExpenseEntry[]
  maintenanceJobs MaintenanceJob[]
  assetLogs       AssetMaintenanceLog[]
  recurringExpenses RecurringExpense[]
  assets          Asset[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([organizationId])
  @@index([name])
}

// ─── Tax Engine ───────────────────────────────────────────────────────────────

enum TaxType {
  ADDITIVE  // VAT, GST — added on top of amount; increases invoice total
  WITHHELD  // WHT, TDS — deducted from gross before remittance to owner/vendor
}

model TaxConfiguration {
  id            String    @id @default(cuid())
  orgId         String
  propertyId    String?                       // null = org-level default for all properties
  label         String                        // e.g. "VAT", "WHT", "GST", "TDS", "Tourism Levy"
  rate          Float                         // decimal: 0.16 = 16%
  type          TaxType
  appliesTo     String[]                      // e.g. ["LONGTERM_RENT", "CONTRACTOR_LABOUR"]
  isInclusive   Boolean   @default(false)     // true = stated amount already includes tax
  isActive      Boolean   @default(true)
  effectiveFrom DateTime  @default(now())     // rate-change history
  createdAt     DateTime  @default(now())

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  property Property?    @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([propertyId])
  @@index([orgId, isActive])
}

// ─── Compliance Certificates ─────────────────────────────────────────────────

model ComplianceCertificate {
  id                  String        @id @default(cuid())
  organizationId      String?
  propertyId          String
  certificateType     String        // free-text: "Gas Safety", "EPC", "HMO License", etc.
  certificateNumber   String?
  issuedBy            String?
  issueDate           DateTime
  expiryDate          DateTime?     // null = ongoing / no expiry
  notes               String?
  documentStoragePath String?
  property            Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  organization        Organization? @relation(fields: [organizationId], references: [id])
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([propertyId])
  @@index([organizationId])
  @@index([expiryDate])
}

// ─── Automated Notifications ─────────────────────────────────────────────────

enum NotificationType {
  LEASE_EXPIRY_30D
  LEASE_EXPIRY_7D
  INVOICE_OVERDUE
  COMPLIANCE_EXPIRY_30D
  COMPLIANCE_EXPIRY_7D
  INSURANCE_EXPIRY_30D
  INSURANCE_EXPIRY_7D
  MAINTENANCE_URGENT_OPEN
}

model NotificationLog {
  id             String           @id @default(cuid())
  organizationId String
  type           NotificationType
  resourceId     String
  resourceType   String
  recipientEmail String
  subject        String
  sentAt         DateTime         @default(now())

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([type, resourceId, sentAt])
  @@index([organizationId, sentAt])
}

// ─── Communication Log ───────────────────────────────────────────────────────

enum CommunicationType {
  EMAIL
}

model CommunicationLog {
  id                String            @id @default(cuid())
  tenantId          String
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type              CommunicationType
  subject           String
  body              String?
  templateUsed      String?
  loggedByEmail     String
  loggedByName      String?
  sentAt            DateTime          @default(now())
  followUpDate      DateTime?
  followUpCompleted Boolean           @default(false)
  createdAt         DateTime          @default(now())

  @@index([tenantId, sentAt])
}

// ─── SaaS Billing Enum ────────────────────────────────────────────────────────

enum PricingTier {
  TRIAL
  STARTER
  GROWTH
  PRO
}
